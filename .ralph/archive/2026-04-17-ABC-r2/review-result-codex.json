   100	// INTERNAL_PRIMITIVES: 부모 컴포넌트가 자동 조립하므로 개별 doc 없음. composition.md 에서 통합 문서화.
   101	// These primitives exist in upstream rootage yaml but are internal implementation details
   102	// assembled automatically by their parent components. They are documented collectively
   103	// in references/decision-matrices/composition.md rather than as individual component docs.
   104	const INTERNAL_PRIMITIVES = new Set([
   105	  "checkmark",
   106	  "radiomark",
   107	  "switchmark",
   108	  "select-box-checkmark",
   109	  "segmented-control-indicator",
   110	  "bottom-sheet-close-button",
   111	  "bottom-sheet-handle",
   112	  "action-sheet-close-button",
   113	  "extended-action-sheet-close-button",
   114	  "menu-sheet-close-button",
   115	  "slider-thumb",
   116	  "slider-tick",
   117	  "field-label",
   118	]);
   119	
   120	// status enum (canonical kebab tags, machine-friendly):
   121	//   ported | not-ported | removed-upstream | local-only | internal-primitive | rootage-only
   122	// details live in the parallel `kind` / `note` fields. Prior plans used legacy
   123	// composite strings like "local-only (slot utility / guidance)" — those were
   124	// dropped in R2 after confirming no external JSON consumers exist in this repo
   125	// (checked via `grep sync-from-seed` across the tree, plus package.json scripts
   126	// and .github/workflows — only README mentions and internal docs reference it).
   127	// If an external consumer is added later, prefer widening the enum or adding a
   128	// new structured field over resurrecting composite strings.
   129	//
   130	// R3 fix (codex review response): even though no external consumer was found in-repo,
   131	// any ad-hoc tooling outside the repo that parsed the pre-R2 composite strings would
   132	// silently break after R2. To keep the migration non-breaking for unknown consumers,
   133	// each entry also carries `legacyStatus` — the exact pre-R2 composite string. New
   134	// code should read `status` + `kind` + `note`; `legacyStatus` exists only as a
   135	// compatibility bridge and may be removed after a full deprecation cycle.
   136	const LEGACY_STATUS_MAP = {
   137	  "local-only": "local-only (slot utility / guidance)",
   138	  "rootage-only": "rootage-only (no React export)",
   139	  "internal-primitive": "internal-primitive (see composition.md)",
   140	  "removed-upstream": "removed-upstream",
   141	  "ported": "ported",
   142	  "not-ported": "not-ported",
   143	};
   144	
   145	function withLegacyStatus(entry) {
   146	  return { ...entry, legacyStatus: LEGACY_STATUS_MAP[entry.status] ?? entry.status };
   147	}
   148	
   149	function diffComponents(upstreamRoot) {
   150	  const report = {};
   151	  const localDir = join(SKILL_ROOT, "references/components");
   152	  const upstreamDir = join(upstreamRoot, "packages/rootage/components");
   153	  if (!existsSync(upstreamDir)) {
   154	    return { error: `upstream components missing: ${upstreamDir}` };
   155	  }
   156	
   157	  const localNames = new Set(
   158	    readdirSync(localDir)
   159	      .filter((f) => f.endsWith(".md") && !f.startsWith("_"))
   160	      .map((f) => f.replace(/\.md$/, "")),
   161	  );
   162	  const upstreamNames = new Set(
   163	    readdirSync(upstreamDir)
   164	      .filter((f) => f.endsWith(".yaml"))
   165	      .map((f) => f.replace(/\.yaml$/, "")),
   166	  );
   167	
   168	  for (const name of localNames) {
   169	    if (LOCAL_ONLY_COMPONENTS.has(name)) {
   170	      report[name] = withLegacyStatus({ status: "local-only", kind: "local-only", note: "slot utility / guidance" });
   171	      continue;
   172	    }
   173	    if (ROOTAGE_ONLY_COMPONENTS.has(name)) {
   174	      report[name] = withLegacyStatus({ status: "rootage-only", kind: "rootage-only", note: "Rootage spec only, no React export" });
   175	      continue;
   176	    }
   177	    if (!upstreamNames.has(name)) {
   178	      report[name] = withLegacyStatus({ status: "removed-upstream", kind: "removed-upstream" });
   179	    } else {
   180	      report[name] = withLegacyStatus({ status: "ported", kind: "ported" });
   181	    }
   182	  }
   183	  for (const name of upstreamNames) {
   184	    if (!localNames.has(name)) {
   185	      if (INTERNAL_PRIMITIVES.has(name)) {
   186	        report[name] = withLegacyStatus({ status: "internal-primitive", kind: "internal-primitive", note: "Documented collectively in decision-matrices/composition.md" });
   187	      } else if (ROOTAGE_ONLY_COMPONENTS.has(name)) {
   188	        report[name] = withLegacyStatus({ status: "rootage-only", kind: "rootage-only" });
   189	      } else {
   190	        report[name] = withLegacyStatus({ status: "not-ported", kind: "not-ported" });
   191	      }
   192	    }
   193	  }
   194	
   195	  return report;
   196	}
   197	
   198	const upstreamRoot = cloneUpstream();
   199	const currentSha = currentUpstreamSha(upstreamRoot);
   200	
   201	const report = {
   202	  snapshotSha: SNAPSHOT.commit,
   203	  upstreamSha: currentSha,
   204	  shaChanged: currentSha && currentSha !== SNAPSHOT.commit,
   205	  tokens: diffTokens(upstreamRoot),
   206	  components: diffComponents(upstreamRoot),
   207	};
   208	
   209	if (jsonOut) {
   210	  process.stdout.write(JSON.stringify(report, null, 2));
   211	  process.exit(0);
   212	}
   213	
   214	log("");
   215	log(`Snapshot SHA:  ${report.snapshotSha}`);
   216	log(`Upstream SHA:  ${report.upstreamSha ?? "(unknown)"}`);
   217	log(`Changed:       ${report.shaChanged ? "YES" : "no"}`);
   218	
   219	log("
== Tokens ==");
   220	const tokenEntries = Object.entries(report.tokens);

