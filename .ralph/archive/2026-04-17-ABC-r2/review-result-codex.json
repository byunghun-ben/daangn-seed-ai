+              <List.Detail>비밀번호, 생체 인증 사용을 관리해요</List.Detail>
+            </List.Content>
+          </button>
+        </List.Item>
+      </List.Root>
+    </div>
+  );
+}
+```
+
+### (b) `variant="boldSolid"` + `as="h3"`
+
+```tsx
+import { List, ListHeader } from "@seed-design/react";
+
