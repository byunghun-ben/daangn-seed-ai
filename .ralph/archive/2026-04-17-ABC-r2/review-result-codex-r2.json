   165	## Props
   166	
   167	`TabsPrimitive.RootProps` 및 `TabsVariantProps` 등 관련 타입은 `@seed-design/react` 에서 직접 re-export 된다. 별도 sub-path import 없이 아래와 같이 사용한다.
   168	
   169	```ts
   170	import type {
   171	  TabsPrimitive,
   172	  TabsVariantProps,   // size: "small" | "medium"; triggerLayout: "hug" | "fill"
   173	} from "@seed-design/react";
   174	
   175	// 1) Tabs.Root — 값 상태 소유
   176	interface TabsRootProps
   177	  extends TabsVariantProps,
   178	          TabsPrimitive.RootProps {
   179	  // 상태
   180	  value?: string;
   181	  defaultValue?: string;
   182	  onValueChange?: (value: string) => void;
   183	
   184	  // 레이아웃
   185	  size?: "small" | "medium";          // default "medium"
   186	  triggerLayout?: "hug" | "fill";     // default "hug"
   187	  orientation?: "horizontal" | "vertical"; // default "horizontal"
   188	
   189	  // 렌더 전략
   190	  lazyMount?: boolean;     // Content를 처음 선택될 때까지 마운트 지연 (default false)
   191	  unmountOnExit?: boolean; // Content가 비선택 시 DOM에서 제거 (default false)
   192	}
   193	
   194	// 2) Tabs.List — 탭 목록 컨테이너 (tablist.yaml root 슬롯)
   195	interface TabsListProps extends TabsPrimitive.ListProps {
   196	  // role="tablist" 자동 부착
   197	  // paddingX / height 는 Root의 size·triggerLayout으로 제어됨
   198	}
   199	
   200	// 3) Tabs.Trigger — 개별 탭 버튼 (tab.yaml 토큰)
   201	interface TabsTriggerProps extends TabsPrimitive.TriggerProps {
   202	  value: string;       // 필수 — Content value와 매핑
   203	  disabled?: boolean;
   204	}
   205	
   206	// 4) Tabs.Indicator — 선택 표시 하단 바 (tablist.yaml indicator 슬롯)
   207	interface TabsIndicatorProps extends TabsPrimitive.IndicatorProps {
   208	  // children 없음. CSS 변수 --indicator-left / --indicator-width 로 위치 자동 계산
   209	  // transform 트랜지션: $duration.d4
   210	}
   211	
   212	// 5) Tabs.Content — 탭 본문 패널
   213	interface TabsContentProps extends TabsPrimitive.ContentProps {
   214	  value: string;       // 필수 — 해당 Trigger value와 동일하게
   215	}
   216	```
