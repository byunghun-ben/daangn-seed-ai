    12	import { SegmentedControl } from "@seed-design/react";
    13	// namespace:
    14	//   <SegmentedControl.Root defaultValue="..." aria-label="...">
    15	//     <SegmentedControl.Indicator />
    16	//     <SegmentedControl.Item value="...">라벨</SegmentedControl.Item>
    17	//     ...
    18	//   </SegmentedControl.Root>
    19	```
