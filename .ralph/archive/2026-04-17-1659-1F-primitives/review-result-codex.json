            {children}
            <NotificationBadgePositioner size=\"small\" attach=\"text\">
              <NotificationBadge />
            </NotificationBadgePositioner>
          </HStack>
        ) : (
          children
        )}
      </SeedSegmentedControl.Item>
    );
  },
);
SegmentedControlItem.displayName = \"SegmentedControlItem\";

