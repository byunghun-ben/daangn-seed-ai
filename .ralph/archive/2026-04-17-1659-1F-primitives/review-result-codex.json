   190	❌ <Avatar.Root style={{ width: 50, height: 50 }}>
   191	     <Avatar.Image src={url} />
   192	   </Avatar.Root>
   193	   {/* size를 px로 하드코딩 — 10개 토큰 중 하나("48")로 지정할 것 */}
   194	
   195	❌ <Avatar.Root size="20" badgeMask="circle">
   196	     <Avatar.Image src={url} />
   197	     <Avatar.Badge>
   198	       <Box bg="palette.green600" borderRadius="full" width="x3" height="x3" />
   199	     </Avatar.Badge>
   200	   </Avatar.Root>
   201	   {/* size=20에서는 badge/badgeMask 미지원 — 무시되거나 잘린다 */}
   202	
   203	❌ <Avatar.Image src={url} />
   204	   {/* Root 없이 Image만 — sizing context 없어 css 적용 안 됨 */}
   205	
   206	❌ <Avatar.Root size="48" style={{ borderRadius: 8 }}>...</Avatar.Root>
   207	   {/* cornerRadius는 full 고정 — square Avatar는 디자인 시스템에 없음 */}
